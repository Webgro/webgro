# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored and must never be committed.
#
# For Vercel deploys: add the same keys in Project Settings → Environment
# Variables. Mark them "Production" (or both Production + Preview if you
# want preview deployments to be fully functional).

# --- Resend (transactional email) -------------------------------------------
# Sign up: https://resend.com (free up to 3,000 emails/month, 100/day).
# Verify the webgro.co.uk domain in Resend so `from:` addresses like
# hello@webgro.co.uk don't land in spam. Then create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions get emailed (your Google Workspace inbox).
CONTACT_TO_EMAIL=hello@webgro.co.uk

# The verified "from" address Resend will send on behalf of. Must match
# the subdomain you verified in Resend (send.webgro.co.uk). Keeps
# transactional email isolated from your Google Workspace reputation.
# The display name ("Webgro Contact") is what recipients see; the
# address itself just needs to live on send.webgro.co.uk.
CONTACT_FROM_EMAIL=hello@send.webgro.co.uk

# --- Cloudflare Turnstile (bot protection) ----------------------------------
# Sign up: https://dash.cloudflare.com/?to=/:account/turnstile
# Create a widget for webgro.co.uk, get the Site Key (public) + Secret Key.
# Use the "Managed" challenge so it's invisible for legit users.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_xxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAA_xxxxxxxxxxxxxxxxxx_secret
